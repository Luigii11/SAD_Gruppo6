<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15" 
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unisa.diem.sad_gruppo6.controller.ui.track.TrackControllerView">
    
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Aggiungi Traccia" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <TextField fx:id="titleField" promptText="Titolo"/>
    <TextField fx:id="authorField" promptText="Autore"/>
    <TextField fx:id="durationField" promptText="Durata (secondi)" editable="false"/>
    <TextField fx:id="genreField" promptText="Genere"/>
    <TextField fx:id="yearField" promptText="Anno"/>
    
    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="pathField" promptText="Percorso file audio" editable="false" HBox.hgrow="ALWAYS"/>
        <Button text="Sfoglia" onAction="#handleBrowseFile"/>
    </HBox>

    <Button text="Aggiungi" onAction="#handleAddTrack"/>
    <Label fx:id="feedbackLabel" style="-fx-text-fill: green;"/>
    
</VBox>