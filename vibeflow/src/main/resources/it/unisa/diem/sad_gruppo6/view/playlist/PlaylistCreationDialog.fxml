<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootContainer" spacing="30.0" styleClass="dialog-pane, main-root" stylesheets="@/styles/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unisa.diem.sad_gruppo6.controller.ui.playlist.PlaylistCreationDialogController">
    
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <children>
            <Label styleClass="brand-title" text="Create Your Playlist" />
            <Label styleClass="cell-meta-label" text="Give your new playlist a name to get started." />
        </children>
    </VBox>

    <HBox alignment="CENTER" spacing="25.0">
        <children>
            
            <StackPane maxHeight="80.0" maxWidth="80.0" minHeight="80.0" minWidth="80.0" 
                       style="-fx-background-color: #1A1A1A; -fx-background-radius: 8px; -fx-border-color: #333333; -fx-border-radius: 8px; -fx-border-width: 1px;">
                <children>
                    <Label style="-fx-font-size: 45px; -fx-text-fill: #5E27BF;" text="♫" />
                </children>
            </StackPane>
            
            <TextField fx:id="playlistName" prefHeight="40.0" prefWidth="250.0" promptText="Playlist Name" styleClass="text-field" />
        </children>
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <children>
            <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" 
                    minHeight="35.0" prefHeight="35.0" maxHeight="35.0" 
                    minWidth="90.0" prefWidth="90.0" maxWidth="90.0" 
                    styleClass="button" text="Cancel" />
            
            <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSave" 
                    minHeight="35.0" prefHeight="35.0" maxHeight="35.0" 
                    minWidth="90.0" prefWidth="90.0" maxWidth="90.0" 
                    styleClass="button" text="Save" />
        </children>
    </HBox>

</VBox>